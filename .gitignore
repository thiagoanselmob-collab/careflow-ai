.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv. But if you're sitting on a system where you use a different version
#   than the one you're coding for, it's a good idea to gitignore it.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different environment, they may opt to
#   ignore Pipfile.lock.
#Pipfile.lock

# poetry
#   According to poetry documentation, poetry.lock should be committed to version control.
#   So we explicitly do NOT ignore poetry.lock.

# pdm
#   Similar to Pipfile.lock, PDM recommends committing pdm.lock in version control
#.pdm.toml
#.pdm-python
#.pdm-build/

# PEP 582; project local packages directory (used by PDM, Poetry etc.)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

